BEDROCK_MODEL_NAME=anthropic.claude-3-5-sonnet-20241022-v2:0
AGNO_DEBUG_MODE=false

# AWS Credentials (for Bedrock access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
